# ---------- API ----------
DATABASE_URL=postgresql://priority:priority@localhost:5432/priority?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
PORT=3000

# ---------- AI layer (OpenAI-compatible; works with OpenAI, Anthropic via gateway, Ollama, etc.) ----------
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
AI_ENABLED=true            # false = deterministic fallback copy, app fully usable offline

# ---------- Mobile ----------
EXPO_PUBLIC_API_URL=http://localhost:3000
