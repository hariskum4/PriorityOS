# ---------- API ----------
DATABASE_URL=postgresql://priority:priority@localhost:5432/priority?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
PORT=3000

# ---------- AI layer (OpenRouter — OpenAI-compatible; also works with OpenAI, Groq, Ollama, etc.) ----------
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-...
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free   # any OpenRouter :free model; lighter alt: openai/gpt-oss-20b:free
AI_ENABLED=true            # false = deterministic fallback copy, app fully usable offline

# ---------- Mobile ----------
EXPO_PUBLIC_API_URL=http://localhost:3000
