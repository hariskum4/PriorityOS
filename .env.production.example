# ============================================================================
# Priority — production environment reference
# Nothing here is secret; fill real values into each PLATFORM's env settings,
# never commit the filled version. Generate secrets with: openssl rand -base64 32
# ============================================================================

# ---------- API (set these on Railway/Render, the service running apps/api) ----------

# Supabase → Project Settings → Database → Connection string.
# Use the POOLED connection (port 6543, "Transaction" mode) for the running app.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# The DIRECT connection (port 5432) — only used by `prisma migrate deploy`.
# Prisma reads this via schema.prisma directUrl if configured; otherwise run
# migrations manually with DATABASE_URL pointed at the direct string once.
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Real random secrets — DO NOT reuse the dev "change-me" values.
JWT_ACCESS_SECRET=<openssl rand -base64 32>
JWT_REFRESH_SECRET=<openssl rand -base64 32>
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# Lock browser access to your deployed web domain(s). Comma-separated.
CORS_ORIGINS=https://your-app.vercel.app

# AI layer (OpenRouter, OpenAI-compatible) — flip ENABLED on in prod to light up the Life Reveal / values extraction.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-...
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free
AI_ENABLED=true

# Redis — optional for MVP (cron runs in-process). Add when you move jobs to BullMQ.
# REDIS_URL=redis://...

# PORT is injected by Railway/Render automatically — do not hardcode.

# ---------- Web (set this on Vercel, build-time) ----------

# Point the web app at the deployed API. Must be set BEFORE the Vercel build,
# because Expo inlines EXPO_PUBLIC_* variables at build time.
EXPO_PUBLIC_API_URL=https://your-api.up.railway.app
